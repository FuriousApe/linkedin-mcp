# Copy this to .env and fill in your values
# NEVER commit .env to git

# Your LinkedIn li_at session cookie value
LINKEDIN_COOKIE=your_li_at_value_here

# Your LinkedIn JSESSIONID cookie value (used as CSRF token)
# Export from Cookie-Editor — it looks like: ajax:1234567890123456789
LINKEDIN_JSESSIONID=ajax:your_jsessionid_here
